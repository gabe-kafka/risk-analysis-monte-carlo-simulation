  <diagram id="mc-flow" name="Monte Carlo Flow">
    <mxGraphModel adaptiveColors="auto" dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
