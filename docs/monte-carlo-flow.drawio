        <mxCell id="title" value="MONTE CARLO SCHEDULE RISK SIMULATION &#8212; DATA FLOW" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=11;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="560" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="INPUT &#8594; TOPO &#8594; ITERATION (N=10,000) &#8594; STATISTICS &#8594; OUTPUTS" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=8;fontColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="40" y="38" width="560" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="hrule" value="" style="line;strokeColor=#D4D4D4;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="560" height="1" as="geometry"/>
        </mxCell>
        <mxCell id="sec1" value="01 &#8212; INPUT" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=8;fontStyle=1;fontColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="200" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="csv1" value="SCHEDULE.CSV&#10;&#10;wbs, activity_id,&#10;activity_name,&#10;duration_days,&#10;predecessors" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="94" width="160" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="csv2" value="RISK-PARAMS.CSV&#10;&#10;activity_id,&#10;optimistic_factor,&#10;most_likely_factor,&#10;pessimistic_factor" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="220" y="94" width="160" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="sec2" value="02 &#8212; PREPROCESS" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=8;fontStyle=1;fontColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="200" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="load" value="LOAD + TOPOLOGICAL SORT&#10;&#10;build DAG, order activities&#10;such that predecessors precede" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="232" width="340" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="det" value="DETERMINISTIC BASELINE&#10;&#10;forward pass with d_i&#10;T_det = max(EF_i)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6B6B6B;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="232" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sec3" value="03 &#8212; MONTE CARLO LOOP" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=8;fontStyle=1;fontColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="40" y="318" width="200" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="loop" value="FOR k = 1 .. N &#8212; ITERATE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0057FF;strokeWidth=2;fontFamily=monospace;fontSize=9;fontStyle=1;fontColor=#0057FF;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="560" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="3.1  SAMPLE DURATIONS&#10;&#10;for each activity i:&#10;d_i^(k) ~ Tri(a_i, m_i, b_i)&#10;where (a,m,b) = (&#945;d, &#956;d, &#946;d)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="56" y="368" width="172" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="3.2  CPM FORWARD PASS&#10;&#10;ES_i = max(EF_j : j in P(i))&#10;EF_i = ES_i + d_i^(k)&#10;&#10;compute all EF_i^(k)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="244" y="368" width="172" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="3.3  RECORD FINISH&#10;&#10;T^(k) = max(EF_i^(k))&#10;&#10;store d_i^(k) for&#10;sensitivity analysis" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="432" y="368" width="152" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="sec4" value="04 &#8212; AGGREGATE + OUTPUT" style="text;html=1;align=left;verticalAlign=middle;fontFamily=monospace;fontSize=8;fontStyle=1;fontColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="40" y="536" width="200" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="out1" value="STATISTICS&#10;&#10;mean, stddev&#10;min, max&#10;percentiles P5..P95" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="558" width="130" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="out2" value="HISTOGRAM&#10;&#10;empirical dist.&#10;of T^(k)&#10;P50/P80/P90 lines" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="180" y="558" width="130" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="out3" value="S-CURVE (CDF)&#10;&#10;F_T(t) = P(T &#8804; t)&#10;confidence&#10;of T_det" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="320" y="558" width="130" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="out4" value="TORNADO&#10;&#10;Spearman &#961;_i&#10;d_i^(k) vs T^(k)&#10;top drivers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A1A1A;strokeWidth=1;fontFamily=monospace;fontSize=9;fontColor=#1A1A1A;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="460" y="558" width="140" height="100" as="geometry"/>
